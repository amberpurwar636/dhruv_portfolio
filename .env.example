
# Step 1 — Sign up at emailjs.com (free plan = 200 emails/month)
# Step 2 — Setup:

# Add Email Service → connect your Gmail → copy Service ID
# Add Email Template → create template with variables {{from_name}}, {{from_email}}, {{message}} → copy Template ID
# Go to Account → copy Public Key

# Step 4 — Update .env.local:
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx

NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=